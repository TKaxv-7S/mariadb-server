--source include/have_innodb.inc
--source include/have_debug.inc
# The embedded server tests do not support restarting.
--source include/not_embedded.inc

--echo #
--echo # MDEV-37467 InnoDB Instant ALTER TABLE is not crash safe
--echo #

CREATE TABLE t1(id INT PRIMARY KEY, c1 INT) ENGINE=InnoDB;
CREATE TABLE t2 LIKE t1;
CREATE TABLE t3 LIKE t1;
CREATE TABLE t4 LIKE t1;
CREATE TABLE t5 LIKE t1;
INSERT INTO t1 VALUES(1, 100);
INSERT INTO t2 VALUES(1, 100);
INSERT INTO t3 VALUES(1, 100);
INSERT INTO t4 VALUES(1, 100);
INSERT INTO t5 VALUES(1, 100);
# Table with INSTANT ADD - MDEV-11369
ALTER TABLE t1 ADD COLUMN c2 VARCHAR(100) DEFAULT 'default_value', ALGORITHM=INSTANT;
# Table with INSTANT ALTER - MDEV-15562
ALTER TABLE t2 ADD COLUMN c2 VARCHAR(100) DEFAULT 'default_value' FIRST, ALGORITHM=INSTANT;

# Test disabled for MDEV-39709
#--error ER_RECORD_FILE_FULL
#SET STATEMENT DEBUG_DBUG="+d,btr_page_alloc_fail" FOR
#ALTER TABLE t1 DROP COLUMN c2, ALGORITHM=INSTANT;
--error ER_RECORD_FILE_FULL
SET STATEMENT DEBUG_DBUG="+d,btr_page_alloc_fail" FOR
ALTER TABLE t2 DROP COLUMN c2, ALGORITHM=INSTANT;
--error ER_RECORD_FILE_FULL
SET STATEMENT DEBUG_DBUG="+d,btr_page_alloc_fail" FOR
ALTER TABLE t3 ADD COLUMN c2 VARCHAR(100) DEFAULT 'default_value' FIRST, ALGORITHM=INSTANT;
--error ER_RECORD_FILE_FULL
SET STATEMENT DEBUG_DBUG="+d,btr_page_alloc_fail" FOR
ALTER TABLE t4 ADD COLUMN c2 BLOB DEFAULT (REPEAT(0x41, 50000)), ALGORITHM=INSTANT;
--error ER_RECORD_FILE_FULL
SET STATEMENT DEBUG_DBUG="+d,btr_page_alloc_fail" FOR
ALTER TABLE t5 ADD COLUMN c2 BLOB DEFAULT (REPEAT(0x41, 50000)) FIRST, ALGORITHM=INSTANT;
--source include/restart_mysqld.inc
SELECT * FROM t1;
SELECT * FROM t2;
SELECT * FROM t3;
SELECT * FROM t4;
SELECT * FROM t5;

DROP TABLE t1,t2,t3,t4,t5;
