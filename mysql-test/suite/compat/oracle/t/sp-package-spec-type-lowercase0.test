if (`SELECT @@lower_case_table_names>0`)
{
   --skip Test requires: lower_case_table_names=0
}


SET sql_mode=ORACLE;

--echo #
--echo # MDEV-39587 Package-wide TYPE for variable declarations
--echo #

DELIMITER $$;
CREATE PACKAGE pkg1 AS
  TYPE rec0_t IS RECORD (a INT, b VARCHAR(32));
  TYPE assoc0_t IS TABLE OF test.pkg1.rec0_t INDEX BY INTEGER;
END;
$$
DELIMITER ;$$
DROP PACKAGE pkg1;

DELIMITER $$;
--error ER_UNKNOWN_DATA_TYPE
CREATE PACKAGE pkg1 AS
  TYPE rec0_t IS RECORD (a INT, b VARCHAR(32));
  TYPE assoc0_t IS TABLE OF TEST.pkg1.rec0_t INDEX BY INTEGER;
END;
$$
DELIMITER ;$$

DELIMITER $$;
--error ER_UNKNOWN_DATA_TYPE
CREATE PACKAGE pkg1 AS
  TYPE rec0_t IS RECORD (a INT, b VARCHAR(32));
  TYPE assoc0_t IS TABLE OF tttt.pkg1.rec0_t INDEX BY INTEGER;
END;
$$
DELIMITER ;$$
