BEGIN
NULL;
END' at line 2
CREATE PROCEDURE p1 AS
r0 pkg1.cur0_t (0,0); -- Length and dec attributes
BEGIN
NULL;
END;
$$
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your MariaDB server version for the right syntax to use near '(0,0); -- Length and dec attributes
BEGIN
NULL;
END' at line 2
CREATE PROCEDURE p1 AS
r0 pkg1.cur0_t CHARACTER SET latin1;
BEGIN
NULL;
END;
$$
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your MariaDB server version for the right syntax to use near 'CHARACTER SET latin1;
BEGIN
NULL;
END' at line 2
