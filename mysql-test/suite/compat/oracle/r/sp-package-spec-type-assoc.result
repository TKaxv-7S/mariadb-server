SET sql_mode=ORACLE;
#
# MDEV-39587 Package-wide TYPE for variable declarations
#
# A too long identifier chain in the TABLE OF type
CREATE PACKAGE pkg1 AS
TYPE assoc0_t IS TABLE OF cat1.db1.pkg1.rec1_t INDEX BY INTEGER;
END;
$$
