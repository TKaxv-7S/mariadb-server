# Assoc array cannot have attributes
# Currently this is not allowed by the parser in qualified types
# If we ever allow, make sure to call check_data_type_attributes()
# which will raise ER_UNSUPPORTED_DATA_TYPE_ATTRIBUTE
CREATE PACKAGE pkg1 AS
TYPE rec0_t IS RECORD (a INT, b VARCHAR(32));
TYPE assoc0_t IS TABLE OF rec0_t INDEX BY INTEGER;
END;
$$
CREATE PROCEDURE p1 AS
r0 pkg1.assoc0_t (0); -- Length attribute
BEGIN
NULL;
END;
$$
