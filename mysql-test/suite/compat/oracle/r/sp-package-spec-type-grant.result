#
# MDEV-40136 User without any privileges on the package schema can declare and use the package's record types
#
CREATE DATABASE secdb;
CREATE PACKAGE secdb.pkg AS
TYPE rec_t IS RECORD (a INT, secret VARCHAR(30));
FUNCTION f RETURN INT;
END;
$$
CREATE PACKAGE BODY secdb.pkg AS
FUNCTION f RETURN INT AS
BEGIN
RETURN 42;
END;
END;
$$
CREATE DATABASE appdb;
CREATE USER u_none@localhost;
GRANT ALL ON appdb.* TO u_none@localhost;
connect  cnone, localhost, u_none,, appdb;
SET sql_mode=ORACLE;
CREATE PROCEDURE appdb.p AS r secdb.pkg.rec_t;
BEGIN
r.a:=1;
r.secret:='x';
SELECT r.a;
END;
$$
ERROR 42000: execute command denied to user 'u_none'@'localhost' for routine 'secdb.pkg'
connection default;
GRANT EXECUTE ON PACKAGE secdb.pkg TO u_none@localhost;
connection cnone;
CREATE PROCEDURE
appdb.p AS r secdb.pkg.rec_t;
BEGIN
r.a:=1;
r.secret:='x';
SELECT r.a;
END;
$$
CALL appdb.p;
r.a
1
SELECT secdb.pkg.f();
ERROR 42000: execute command denied to user 'u_none'@'localhost' for routine 'secdb.pkg'
connection default;
GRANT EXECUTE ON PACKAGE BODY secdb.pkg TO u_none@localhost;
connection cnone;
SELECT secdb.pkg.f();
secdb.pkg.f()
42
connection default;
disconnect cnone;
DROP USER u_none@localhost;
DROP DATABASE appdb;
DROP DATABASE secdb;
