#
# MDEV-39587 Package-wide TYPE for variable declarations
#
SET sql_mode=ORACLE;
CREATE DATABASE test1;
CREATE DATABASE test2;
CREATE USER user1@localhost;
CREATE USER user2@localhost;
GRANT CREATE ROUTINE ON test1.* TO user1@localhost;
GRANT CREATE ROUTINE ON test2.* TO user1@localhost;
GRANT CREATE ROUTINE ON test1.* TO user2@localhost;
GRANT CREATE ROUTINE ON test2.* TO user2@localhost;
connect  conn_user1, localhost, user1,, test1;
SET sql_mode=ORACLE;
connect  conn_user2, localhost, user2,, test1;
SET sql_mode=ORACLE;
connection conn_user1;
CREATE PACKAGE pkg1 AS
TYPE rec0_t IS RECORD (a INT, b VARCHAR(10));
TYPE cur0_t IS REF CURSOR RETURN rec0_t;
END;
$$
connection conn_user1;
# Start of allowed.inc
SELECT CURRENT_USER;
CURRENT_USER
user1@localhost
#
# ACL_NONE + same user + same DB
#
USE test1;
# ACL_NONE + same user + same DB + PACKAGE type in the same PACKAGE BODY
CREATE PACKAGE BODY pkg1 AS
r0 pkg1.rec0_t;
END;
$$
DROP PACKAGE BODY pkg1;
CREATE PACKAGE BODY pkg1 AS
r0 test1.pkg1.rec0_t;
END;
$$
DROP PACKAGE BODY pkg1;
# ACL_NONE + same user + same DB + PACKAGE type in another PACKAGE
CREATE PACKAGE pkg2 AS
TYPE cur1_t IS REF CURSOR RETURN pkg1.rec0_t;
END;
$$
DROP PACKAGE pkg2;
CREATE PACKAGE pkg2 AS
TYPE cur1_t IS REF CURSOR RETURN test1.pkg1.rec0_t;
END;
$$
