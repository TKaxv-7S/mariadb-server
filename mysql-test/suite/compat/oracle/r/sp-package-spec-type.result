# PACKAGE gets dropped making an orphan type reference: 2-step
CREATE PACKAGE pkg1 AS
TYPE rec0_t IS RECORD(a INT, b VARCHAR(30));
END;
$$
CREATE PROCEDURE p1 AS
r0 pkg1.rec0_t;
BEGIN
r0.a:= 10;
r0.b:= 'b';
SELECT r0.a, r0.b;
END;
$$
CALL p1;
r0.a	r0.b
10	b
DROP PACKAGE pkg1;
CALL p1;
ERROR HY000: Failed to load routine test.p1 (internal code -6). For more details, run SHOW WARNINGS
SHOW WARNINGS;
Level	Code	Message
Error	4161	Unknown data type: '`pkg1`.`rec0_t`'
Error	1457	Failed to load routine test.p1 (internal code -6). For more details, run SHOW WARNINGS
DROP PROCEDURE p1;
# PACKAGE gets dropped making an orphan type reference: 3-step
CREATE PACKAGE pkg1 AS
TYPE rec0_t IS RECORD(a INT, b VARCHAR(30));
END;
$$
CREATE DATABASE test1;
USE test1;
CREATE PROCEDURE p1 AS
r0 test.pkg1.rec0_t;
BEGIN
r0.a:= 10;
r0.b:= 'b';
SELECT r0.a, r0.b;
END;
$$
CALL p1;
r0.a	r0.b
10	b
DROP PACKAGE test.pkg1;
CALL p1;
ERROR HY000: Failed to load routine test1.p1 (internal code -6). For more details, run SHOW WARNINGS
SHOW WARNINGS;
Level	Code	Message
Error	4161	Unknown data type: '`test`.`pkg1`.`rec0_t`'
Error	1457	Failed to load routine test1.p1 (internal code -6). For more details, run SHOW WARNINGS
DROP PROCEDURE p1;
DROP DATABASE test1;
USE test;
# Too long identifier chain
CREATE PROCEDURE p1 AS
v1 cat1.db1.pkg1.type1;
BEGIN
NULL;
END;
$$
ERROR HY000: Unknown data type: '`cat1`.`db1`.`pkg1`'
#
# MDEV-40155 Weak REF CURSOR without RETURN is not opened using a dynamic SQL statement
#
CREATE TABLE t (id INT, name VARCHAR(100));
INSERT INTO t VALUES (1,'Test');
CREATE PACKAGE pc AS TYPE wc IS REF CURSOR; END;
$$
CREATE PROCEDURE pdyn AS
c pc.wc;
vi INT;
vn VARCHAR(100);
BEGIN
OPEN c FOR 'SELECT id, name FROM t';
FETCH c INTO vi, vn;
SELECT vi, vn;
CLOSE c;
END;
$$
CALL pdyn;
vi	vn
1	Test
DROP PROCEDURE pdyn;
DROP PACKAGE pc;
DROP TABLE t;
#
# MDEV-40153 Assertion `rec->field->head()->charset == nullptr' failed in virtual bool Type_handler_row::Column_definition_prepare_stage1(THD *, MEM_ROOT *, Column_definition *, column_definition_type_t, const Column_derived_attributes *) const
#
CREATE PACKAGE pk_crash AS
TYPE r IS RECORD (b BLOB);
FUNCTION f RETURN r;
END;
$$
DROP PACKAGE pk_crash;
CREATE PACKAGE pk_crash AS
TYPE rec0_t IS RECORD (b BLOB);
FUNCTION f(r rec0_t) RETURN INT;
END;
$$
DROP PACKAGE pk_crash;
