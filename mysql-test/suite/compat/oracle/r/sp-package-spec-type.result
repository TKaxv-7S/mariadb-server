# PACKAGE gets dropped making an orphan type reference: 2-step
CREATE PACKAGE pkg1 AS
TYPE rec0_t IS RECORD(a INT, b VARCHAR(30));
END;
$$
CREATE PROCEDURE p1 AS
r0 pkg1.rec0_t;
BEGIN
r0.a:= 10;
r0.b:= 'b';
SELECT r0.a, r0.b;
END;
$$
CALL p1;
r0.a	r0.b
10	b
DROP PACKAGE pkg1;
