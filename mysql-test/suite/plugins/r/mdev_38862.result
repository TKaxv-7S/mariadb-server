CREATE USER 'audit_user1'@'localhost' IDENTIFIED BY 'password1';
CREATE USER 'audit_user2'@'localhost' IDENTIFIED BY 'password2';
CREATE USER 'audit_user3'@'localhost' IDENTIFIED BY 'password3';
GRANT ALL ON *.* TO 'audit_user1'@'localhost';
GRANT ALL ON *.* TO 'audit_user2'@'localhost';
GRANT ALL ON *.* TO 'audit_user3'@'localhost';
INSTALL PLUGIN server_audit SONAME 'server_audit';
SET GLOBAL server_audit_logging = OFF;
SET GLOBAL server_audit_events = 'QUERY';
SET GLOBAL server_audit_output_type = 'FILE';
SET GLOBAL server_audit_file_path = 'server_audit.log';
# Testing double Commas, Edge Commas, & Whitespace (INCL_USERS)
SET GLOBAL server_audit_incl_users = 'audit_user1,,audit_user2';
SET GLOBAL server_audit_logging = ON;
connect  conn1, localhost, audit_user1, password1,;
SELECT 'incl_test_user1';
incl_test_user1
incl_test_user1
connection default;
SET GLOBAL server_audit_incl_users = ',audit_user1,audit_user2,';
connect  conn2, localhost, audit_user2, password2,;
SELECT 'incl_test_user2';
incl_test_user2
incl_test_user2
connection default;
SET GLOBAL server_audit_incl_users = 'audit_user1  ,  ,  audit_user2';
connect  conn3, localhost, audit_user3, password3,;
SELECT 'incl_test_user3_SHOULD_NOT_LOG';
incl_test_user3_SHOULD_NOT_LOG
incl_test_user3_SHOULD_NOT_LOG
connection default;
SET GLOBAL server_audit_logging = OFF;
TIME,HOSTNAME,root,localhost,CONNECTION_ID,QUERY_ID,QUERY,test,'SET GLOBAL server_audit_logging = ON',0
TIME,HOSTNAME,audit_user1,localhost,CONNECTION_ID,QUERY_ID,QUERY,test,'SELECT \'incl_test_user1\'',0
TIME,HOSTNAME,root,localhost,CONNECTION_ID,QUERY_ID,QUERY,test,'SET GLOBAL server_audit_incl_users = \',audit_user1,audit_user2,\'',0
TIME,HOSTNAME,audit_user2,localhost,CONNECTION_ID,QUERY_ID,QUERY,test,'SELECT \'incl_test_user2\'',0
TIME,HOSTNAME,root,localhost,CONNECTION_ID,QUERY_ID,QUERY,test,'SET GLOBAL server_audit_incl_users = \'audit_user1  ,  ,  audit_user2\'',0
TIME,HOSTNAME,root,localhost,CONNECTION_ID,QUERY_ID,QUERY,test,'SET GLOBAL server_audit_logging = OFF',0
# Double Commas in EXCL_USERS
SET GLOBAL server_audit_incl_users = '';
SET GLOBAL server_audit_excl_users = 'audit_user1,,audit_user2';
SET GLOBAL server_audit_logging = ON;
connection conn1;
SELECT 'excl_test_user1_SHOULD_NOT_LOG';
excl_test_user1_SHOULD_NOT_LOG
excl_test_user1_SHOULD_NOT_LOG
connection conn3;
SELECT 'excl_test_user3_SHOULD_LOG';
excl_test_user3_SHOULD_LOG
excl_test_user3_SHOULD_LOG
connection default;
SET GLOBAL server_audit_logging = OFF;
TIME,HOSTNAME,root,localhost,CONNECTION_ID,QUERY_ID,QUERY,test,'SET GLOBAL server_audit_logging = ON',0
TIME,HOSTNAME,audit_user3,localhost,CONNECTION_ID,QUERY_ID,QUERY,test,'SELECT \'excl_test_user3_SHOULD_LOG\'',0
TIME,HOSTNAME,root,localhost,CONNECTION_ID,QUERY_ID,QUERY,test,'SET GLOBAL server_audit_logging = OFF',0
# Empty Inputs so fallback and log all
SET GLOBAL server_audit_excl_users = '';
SET GLOBAL server_audit_incl_users = ' , ,, ';
SET GLOBAL server_audit_logging = ON;
connection conn3;
SELECT 'empty_test_user3_SHOULD_LOG';
empty_test_user3_SHOULD_LOG
empty_test_user3_SHOULD_LOG
connection default;
SET GLOBAL server_audit_logging = OFF;
TIME,HOSTNAME,root,localhost,CONNECTION_ID,QUERY_ID,QUERY,test,'SET GLOBAL server_audit_logging = ON',0
TIME,HOSTNAME,audit_user3,localhost,CONNECTION_ID,QUERY_ID,QUERY,test,'SELECT \'empty_test_user3_SHOULD_LOG\'',0
TIME,HOSTNAME,root,localhost,CONNECTION_ID,QUERY_ID,QUERY,test,'SET GLOBAL server_audit_logging = OFF',0
# Cleanup
disconnect conn1;
disconnect conn2;
disconnect conn3;
connection default;
UNINSTALL PLUGIN server_audit;
DROP USER 'audit_user1'@'localhost';
DROP USER 'audit_user2'@'localhost';
DROP USER 'audit_user3'@'localhost';
