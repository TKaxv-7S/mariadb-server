--source include/not_embedded.inc
--source include/no_view_protocol.inc
--disable_ps2_protocol

CREATE USER 'audit_user1'@'localhost' IDENTIFIED BY 'password1';
CREATE USER 'audit_user2'@'localhost' IDENTIFIED BY 'password2';
CREATE USER 'audit_user3'@'localhost' IDENTIFIED BY 'password3';
GRANT ALL ON *.* TO 'audit_user1'@'localhost';
GRANT ALL ON *.* TO 'audit_user2'@'localhost';
GRANT ALL ON *.* TO 'audit_user3'@'localhost';

INSTALL PLUGIN server_audit SONAME 'server_audit';
let $MYSQLD_DATADIR= `SELECT @@datadir`;

# Core configuration profile
SET GLOBAL server_audit_logging = OFF;
SET GLOBAL server_audit_events = 'QUERY';
SET GLOBAL server_audit_output_type = 'FILE';
SET GLOBAL server_audit_file_path = 'server_audit.log';

--echo # Testing double Commas, Edge Commas, & Whitespace (INCL_USERS)

SET GLOBAL server_audit_incl_users = 'audit_user1,,audit_user2';
SET GLOBAL server_audit_logging = ON;
--connect (conn1, localhost, audit_user1, password1,)
SELECT 'incl_test_user1';

--connection default
SET GLOBAL server_audit_incl_users = ',audit_user1,audit_user2,';
--connect (conn2, localhost, audit_user2, password2,)
SELECT 'incl_test_user2';

--connection default
SET GLOBAL server_audit_incl_users = 'audit_user1  ,  ,  audit_user2';
--connect (conn3, localhost, audit_user3, password3,)
SELECT 'incl_test_user3_SHOULD_NOT_LOG';

--connection default
SET GLOBAL server_audit_logging = OFF;

# Validate inclusion results: user3 should not be there
--replace_regex /[0-9]* [0-9][0-9]:[0-9][0-9]:[0-9][0-9],[^,]*,/TIME,HOSTNAME,/ /,[0-9]+,[0-9]+,/,CONNECTION_ID,QUERY_ID,/ /localhost:[0-9]+/localhost/
--cat_file $MYSQLD_DATADIR/server_audit.log
--remove_file $MYSQLD_DATADIR/server_audit.log

--echo # Double Commas in EXCL_USERS
SET GLOBAL server_audit_incl_users = ''; 
SET GLOBAL server_audit_excl_users = 'audit_user1,,audit_user2';
SET GLOBAL server_audit_logging = ON;

--connection conn1
SELECT 'excl_test_user1_SHOULD_NOT_LOG';
--connection conn3
SELECT 'excl_test_user3_SHOULD_LOG';

--connection default
SET GLOBAL server_audit_logging = OFF;

# Validate exclusion results: user1 should not be there
--replace_regex /[0-9]* [0-9][0-9]:[0-9][0-9]:[0-9][0-9],[^,]*,/TIME,HOSTNAME,/ /,[0-9]+,[0-9]+,/,CONNECTION_ID,QUERY_ID,/ /localhost:[0-9]+/localhost/
--cat_file $MYSQLD_DATADIR/server_audit.log
--remove_file $MYSQLD_DATADIR/server_audit.log


--echo # Empty Inputs so fallback and log all
SET GLOBAL server_audit_excl_users = ''; 
SET GLOBAL server_audit_incl_users = ' , ,, ';
SET GLOBAL server_audit_logging = ON;

--connection conn3
SELECT 'empty_test_user3_SHOULD_LOG';

--connection default
SET GLOBAL server_audit_logging = OFF;

# Validate fallback results: user3 should be logged since filter evaluates to empty
--replace_regex /[0-9]* [0-9][0-9]:[0-9][0-9]:[0-9][0-9],[^,]*,/TIME,HOSTNAME,/ /,[0-9]+,[0-9]+,/,CONNECTION_ID,QUERY_ID,/ /localhost:[0-9]+/localhost/
--cat_file $MYSQLD_DATADIR/server_audit.log
--remove_file $MYSQLD_DATADIR/server_audit.log

--echo # Cleanup

--disconnect conn1
--disconnect conn2
--disconnect conn3

--connection default
--disable_warnings
UNINSTALL PLUGIN server_audit;
--enable_warnings

DROP USER 'audit_user1'@'localhost';
DROP USER 'audit_user2'@'localhost';
DROP USER 'audit_user3'@'localhost';

--enable_ps2_protocol
