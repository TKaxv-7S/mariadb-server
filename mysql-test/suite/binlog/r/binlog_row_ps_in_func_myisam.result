#
# Package, with SYS_REFCURSOR
#
SET sql_mode=ORACLE;
RESET MASTER;
CREATE TABLE t1 (a INT);
SHOW CREATE TABLE t1;
Table	Create Table
t1	CREATE TABLE "t1" (
  "a" int(11) DEFAULT NULL
)
INSERT INTO t1 VALUES (10), (20);
CREATE PACKAGE pkg1 AS
PROCEDURE parse(query TEXT);
FUNCTION exec() RETURN INT;
PROCEDURE close();
END;
$$
CREATE PACKAGE BODY pkg1 AS
PROCEDURE parse(query TEXT) AS
BEGIN
PREPARE stmt FROM query;
END;
FUNCTION exec() RETURN INT AS
c0 SYS_REFCURSOR;
nrows INT:= 0;
v0 INT;
BEGIN
OPEN c0 FOR PREPARE stmt;
LOOP
FETCH c0 INTO v0;
EXIT WHEN c0%NOTFOUND;
EXECUTE IMMEDIATE 'INSERT INTO t1 VALUES (?)' USING v0+100;
nrows := nrows + 1;
END LOOP;
CLOSE c0;
RETURN nrows;
END;
PROCEDURE close() AS
BEGIN
DEALLOCATE PREPARE stmt;
END;
END;
$$
CALL pkg1.parse('SELECT a FROM t1');
START TRANSACTION;
DECLARE
nrows INT;
BEGIN 
SET nrows= pkg1.exec();
SELECT nrows;
EXECUTE IMMEDIATE 'INSERT INTO t1 VALUES (200)'; -- Additional INSERT
END;
$$
nrows
2
COMMIT;
CALL pkg1.close();
SELECT * FROM t1;
a
10
20
110
120
200
DROP PACKAGE pkg1;
SELECT * FROM t1;
a
10
20
110
120
200
DROP TABLE t1;
SET sql_mode=DEFAULT;
