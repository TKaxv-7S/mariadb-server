SET default_storage_engine=MyISAM;
#
# MDEV-39518 Allow prepared statements in stored functions in assignment 
#
#
# p3(set) - f2(set) - f1(immediate)
#
RESET MASTER;
CREATE TABLE t1 (a INT);
SHOW CREATE TABLE t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `a` int(11) DEFAULT NULL
) ENGINE=MyISAM DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_uca1400_ai_ci
CREATE FUNCTION f1_immediate() RETURNS INT
BEGIN
EXECUTE IMMEDIATE 'INSERT INTO t1 VALUES (10)';
RETURN 10;
END;
$$
CREATE FUNCTION f2_set() RETURNS INT
BEGIN
DECLARE nrows INT;
SET nrows= f1_immediate();
RETURN nrows;
END;
$$
CREATE PROCEDURE p3_set()
BEGIN
DECLARE nrows INT;
SET nrows= f2_set();
END;
$$
START TRANSACTION;
CALL p3_set;
COMMIT;
SELECT * FROM t1;
a
10
DROP PROCEDURE p3_set;
DROP FUNCTION f2_set;
DROP FUNCTION f1_immediate;
DROP TABLE t1;
