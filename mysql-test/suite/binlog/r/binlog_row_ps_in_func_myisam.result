PROCEDURE parse(query TEXT) AS
BEGIN
PREPARE stmt FROM query;
END;
FUNCTION exec() RETURN INT AS
c0 SYS_REFCURSOR;
nrows INT:= 0;
v0 INT;
BEGIN
OPEN c0 FOR PREPARE stmt;
LOOP
FETCH c0 INTO v0;
EXIT WHEN c0%NOTFOUND;
EXECUTE IMMEDIATE 'INSERT INTO t1 VALUES (?)' USING v0+100;
nrows := nrows + 1;
END LOOP;
CLOSE c0;
RETURN nrows;
END;
PROCEDURE close() AS
BEGIN
DEALLOCATE PREPARE stmt;
END;
END
