include/master-slave.inc
[connection master]
#
# MDEV-39518 Allow prepared statements in stored functions in assignment right hand
#
#
# p3(set) - f2(set,immediate) - f1(immediate)
#
connection master;
CREATE TABLE t1 (a INT);
CREATE FUNCTION f1_immediate() RETURNS INT
BEGIN
EXECUTE IMMEDIATE 'INSERT INTO t1 VALUES (10)';
RETURN 10;
END;
$$
CREATE FUNCTION f2_set_immediate() RETURNS INT
BEGIN
DECLARE nrows INT;
SET nrows= f1_immediate();
EXECUTE IMMEDIATE 'INSERT INTO t1 VALUES (11)';
RETURN nrows;
END;
$$
CREATE PROCEDURE p3_set()
BEGIN
DECLARE nrows INT;
SET nrows= f2_set_immediate();
END;
$$
CALL p3_set;
SELECT * FROM t1;
a
10
11
connection slave;
SELECT * FROM t1;
a
10
11
connection master;
DROP PROCEDURE p3_set;
DROP FUNCTION f2_set_immediate;
DROP FUNCTION f1_immediate;
DROP TABLE t1;
connection slave;
#
# Package
#
connection master;
CREATE TABLE t1 (a INT);
CREATE PACKAGE pkg1
PROCEDURE parse(query TEXT);
FUNCTION exec() RETURNS INT;
PROCEDURE close();
END;
$$
CREATE PACKAGE BODY pkg1
PROCEDURE parse(query TEXT)
BEGIN
PREPARE stmt FROM query;
END;
FUNCTION exec() RETURNS INT
BEGIN
EXECUTE stmt;
RETURN ROW_COUNT();
END;
PROCEDURE close()
BEGIN
DEALLOCATE PREPARE stmt;
END;
END;
$$
CALL pkg1.parse('INSERT INTO t1 VALUES (10)');
BEGIN NOT ATOMIC
DECLARE nrows INT;
SET nrows= pkg1.exec();
SELECT nrows;
EXECUTE IMMEDIATE 'INSERT INTO t1 VALUES (11)';
END;
$$
nrows
1
CALL pkg1.close();
SELECT * FROM t1;
a
10
11
connection slave;
SELECT * FROM t1;
a
10
11
connection master;
DROP PACKAGE pkg1;
SELECT * FROM t1;
a
10
11
DROP TABLE t1;
connection slave;
