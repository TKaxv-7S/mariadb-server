--echo #
--echo # MDEV-39518 Allow prepared statements in stored functions in assignment right hand
--echo #

--echo #
--echo # A stored function with PS used from a trigger
--echo # Not allowed even in a safe context (e.g. assignment in right hand)
--echo #

CREATE TABLE t1 (a INT);
INSERT INTO t1 VALUES (10);
DELIMITER $$;
CREATE FUNCTION f1() RETURNS INT
BEGIN
  EXECUTE IMMEDIATE 'UPDATE t1 SET a=11';
  RETURN ROW_COUNT();
END;
$$
CREATE PROCEDURE p1()
BEGIN
  DECLARE nrows INT DEFAULT f1();
END;
$$
CALL p1;
CREATE TRIGGER tr1 AFTER INSERT ON t1 FOR EACH ROW
BEGIN
  CALL p1;
END;
$$
DELIMITER ;$$
--error ER_STMT_NOT_ALLOWED_IN_SF_OR_TRG
INSERT INTO t1 VALUES (12);
DROP FUNCTION f1;
DROP PROCEDURE p1;
DROP TABLE t1;


--echo #
--echo # MDEV-40224 SIGSEGV in THD::is_error | Item::save_in_field | Item_trigger_field::set_value
--echo #

CREATE TABLE t1(a INT, b INT);
DELIMITER $$;
CREATE FUNCTION f() RETURNS INT
BEGIN
  EXECUTE IMMEDIATE 'SELECT 1';
  RETURN 5;
END;
$$
CREATE TRIGGER tr BEFORE INSERT ON t1 FOR EACH ROW SET NEW.b = f();
$$
DELIMITER ;$$
--error ER_STMT_NOT_ALLOWED_IN_SF_OR_TRG
INSERT INTO t1(a) VALUES (1);
DROP TABLE t1;
DROP FUNCTION f;


CREATE TABLE t1(a INT, b INT);
DELIMITER $$;
CREATE FUNCTION f1() RETURNS INT
BEGIN
  EXECUTE IMMEDIATE 'SELECT 1';
  RETURN 5;
END;
$$
CREATE FUNCTION f2() RETURNS INT
BEGIN
  DECLARE rc INT;
  SET rc= f1();
  RETURN rc;
END;
$$
CREATE TRIGGER tr BEFORE INSERT ON t1 FOR EACH ROW SET NEW.b = f2()
$$
DELIMITER ;$$
--error ER_STMT_NOT_ALLOWED_IN_SF_OR_TRG
INSERT INTO t1(a) VALUES (1);
DROP FUNCTION f2;
DROP FUNCTION f1;
DROP TABLE t1;


--echo #
--echo # MDEV-40285 Assertion DBUG_ASSERT(thd->lock == 0) failed in lock_tables()
--echo #

CREATE TABLE t1 (a INT, b INT);
DELIMITER $$;
CREATE FUNCTION f() RETURNS INT
BEGIN
  EXECUTE IMMEDIATE 'SELECT 1';
  RETURN 5;
END;
$$
CREATE TRIGGER tr AFTER INSERT ON t1 FOR EACH ROW
BEGIN
  UPDATE t1 SET b=f();
END;
$$
DELIMITER ;$$
--error ER_STMT_NOT_ALLOWED_IN_SF_OR_TRG
INSERT INTO t1(a) VALUES (1);
DROP FUNCTION f;
DROP TABLE t1;


# A longer stack
CREATE TABLE t1(a INT, b INT);
DELIMITER $$;
CREATE FUNCTION f1() RETURNS INT
BEGIN
  EXECUTE IMMEDIATE 'SELECT 1';
  RETURN 5;
END;
$$
CREATE FUNCTION f2() RETURNS INT
BEGIN
  DECLARE res INT default f1();
  RETURN res;
END;
$$
CREATE TRIGGER tr AFTER INSERT ON t1 FOR EACH ROW
BEGIN
  UPDATE t1 SET b=f2();
END;
$$
DELIMITER ;$$
--error ER_STMT_NOT_ALLOWED_IN_SF_OR_TRG
INSERT INTO t1(a) VALUES (1);
DROP FUNCTION f2;
DROP FUNCTION f1;
DROP TABLE t1;
