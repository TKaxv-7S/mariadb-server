#
# MDEV-39518 Allow prepared statements in stored functions in assignment
#
# P(none,default/set)-F(none,set)-F(immediate)
CREATE TABLE t1 (a INT);
CREATE FUNCTION f_immediate() RETURNS INT
BEGIN
EXECUTE IMMEDIATE 'INSERT INTO t1 VALUES (10)';
RETURN ROW_COUNT();
END;
$$
CREATE FUNCTION f2_set() RETURNS INT
BEGIN
DECLARE nrows INT;
SET nrows= f_immediate();
RETURN nrows;
END;
$$
CREATE PROCEDURE p3_default()
BEGIN
DECLARE nrows INT DEFAULT f2_set();
END;
$$
CREATE PROCEDURE p3_set()
BEGIN
DECLARE nrows INT;
SET nrows= f2_set();
SELECT nrows;
END;
$$
CREATE PROCEDURE p3_select()
BEGIN
SELECT f2_set();
END;
$$
CALL p3_select();
ERROR 0A000: Dynamic SQL is not allowed in stored function or trigger
CALL p3_default;
CALL p3_default;
SELECT * FROM t1;
a
10
10
TRUNCATE TABLE t1;
CALL p3_set;
nrows
1
CALL p3_set;
nrows
1
SELECT * FROM t1;
a
10
10
DROP PROCEDURE p3_select;
DROP PROCEDURE p3_default;
DROP PROCEDURE p3_set;
DROP FUNCTION f2_set;
DROP FUNCTION f_immediate;
DROP TABLE t1;
# P(none,default/set)-F(none,default)-F(immediate)
