--echo #
--echo # MDEV-39518 Allow prepared statements in stored functions in assignment right hand
--echo #

--echo #
--echo # A function with PREPARE/EXECUTE/DEALLOCATE can be used with restrictions
--echo # OK when the function is used in an assignment right hand
--echo #

CREATE TABLE t1 (a INT);
DELIMITER $$;
CREATE FUNCTION f1() RETURNS INT
BEGIN
  PREPARE stmt FROM 'INSERT INTO t1 VALUES (10)';
  RETURN 0;
END;
$$
DELIMITER ;$$
--error ER_STMT_NOT_ALLOWED_IN_SF_OR_TRG
SELECT f1();
DELIMITER $$;
CREATE PROCEDURE p1()
BEGIN
  DECLARE a INT DEFAULT f1();
END;
$$
DELIMITER ;$$
CALL p1;
CALL p1;
EXECUTE stmt;
SELECT * FROM t1;
DROP PROCEDURE p1;
DROP FUNCTION f1;
TRUNCATE TABLE t1;


DELIMITER $$;
CREATE FUNCTION f1() RETURNS INT
BEGIN
  EXECUTE stmt;
  RETURN 0;
END;
$$
DELIMITER ;$$
--error ER_STMT_NOT_ALLOWED_IN_SF_OR_TRG
SELECT f1();
DELIMITER $$;
CREATE PROCEDURE p1()
BEGIN
  DECLARE a INT DEFAULT f1();
END;
$$
DELIMITER ;$$
CALL p1;
CALL p1;
SELECT * FROM t1;
DROP PROCEDURE p1;
DROP FUNCTION f1;


DELIMITER $$;
CREATE FUNCTION f1() RETURNS INT
BEGIN
  DEALLOCATE PREPARE stmt;
  RETURN 0;
END;
$$
DELIMITER ;$$
--error ER_STMT_NOT_ALLOWED_IN_SF_OR_TRG
SELECT f1();
DELIMITER $$;
CREATE PROCEDURE p1()
BEGIN
  DECLARE a INT DEFAULT f1();
END;
$$
DELIMITER ;$$
CALL p1;
--error ER_UNKNOWN_STMT_HANDLER
DEALLOCATE PREPARE stmt;
DROP PROCEDURE p1;
DROP FUNCTION f1;


DELIMITER $$;
CREATE FUNCTION f1() RETURNS INT
BEGIN
  EXECUTE IMMEDIATE 'INSERT INTO t1 VALUES (10)';
  RETURN 0;
END;
$$
DELIMITER ;$$
--error ER_STMT_NOT_ALLOWED_IN_SF_OR_TRG
SELECT f1();
DELIMITER $$;
CREATE PROCEDURE p1()
BEGIN
  DECLARE a INT DEFAULT f1();
END;
$$
DELIMITER ;$$
CALL p1;
CALL p1;
SELECT * FROM t1;
DROP PROCEDURE p1;
DROP FUNCTION f1;
DROP TABLE t1;


--echo #
--echo # DML statements
--echo #

CREATE TABLE t1 (a INT);

DELIMITER $$;
CREATE FUNCTION f1(query TEXT) RETURNS INT
BEGIN
  DECLARE nrows INT;
  PREPARE stmt FROM query;
  EXECUTE stmt;
  SET nrows= ROW_COUNT();
  DEALLOCATE PREPARE stmt;
  RETURN nrows;
END;
$$
CREATE PROCEDURE p1(query TEXT)
BEGIN
  DECLARE nrows INT;
  SET nrows= f1(query);
  SELECT nrows;
  SELECT * FROM t1;
END;
$$
DELIMITER ;$$
CALL p1('INSERT INTO t1 VALUES (10),(20),(30)');
CALL p1('UPDATE t1 SET a=a+1');
CALL p1('DELETE FROM t1 WHERE a>20');
DROP PROCEDURE p1;
DROP FUNCTION f1;
DROP TABLE t1;


--echo #
--echo # A stored function with PS used from a trigger
--echo # Not allowed even in a safe context (e.g. assignment in right hand)
--echo #

CREATE TABLE t1 (a INT);
INSERT INTO t1 VALUES (10);
DELIMITER $$;
CREATE FUNCTION f1() RETURNS INT
BEGIN
  EXECUTE IMMEDIATE 'UPDATE t1 SET a=11';
  RETURN ROW_COUNT();
END;
$$
CREATE PROCEDURE p1()
BEGIN
  DECLARE nrows INT DEFAULT f1();
END;
$$
CALL p1;
CREATE TRIGGER tr1 AFTER INSERT ON t1 FOR EACH ROW
BEGIN
  CALL p1;
END;
$$
DELIMITER ;$$
--error ER_STMT_NOT_ALLOWED_IN_SF_OR_TRG
INSERT INTO t1 VALUES (12);
DROP FUNCTION f1;
DROP PROCEDURE p1;
DROP TABLE t1;


--echo #
--echo # A stored function with PS used from a view
--echo # Not allowed
--echo #

CREATE TABLE t1 (a INT);
INSERT INTO t1 VALUES (10);
DELIMITER $$;
CREATE FUNCTION f1() RETURNS INT
BEGIN
  EXECUTE IMMEDIATE 'UPDATE t1 SET a=11';
  UPDATE t1 SET a=11;
  RETURN ROW_COUNT();
END;
$$
CREATE FUNCTION f2() RETURNS INT
BEGIN
  DECLARE nrows INT;
  SET nrows= f1();
  RETURN nrows;
END;
$$
DELIMITER ;$$
CREATE VIEW v1 AS SELECT f1() AS c1;
--error ER_STMT_NOT_ALLOWED_IN_SF_OR_TRG
SELECT * FROM v1;
CREATE VIEW v2 AS SELECT f2() AS c1;
--error ER_STMT_NOT_ALLOWED_IN_SF_OR_TRG
SELECT * FROM v2;
DROP VIEW v1;
DROP VIEW v2;
SELECT * FROM t1;
DROP FUNCTION f2;
DROP FUNCTION f1;
DROP TABLE t1;
