# 3. Role-CREATE dedup (regression for ER 1396 on shared roles).
SELECT 'm8_shared_role' AS role, COUNT(*) AS grant_count
FROM mysql.roles_mapping
WHERE Role='m8_shared_role';
role	grant_count
m8_shared_role	5
# 4. Default-role assignment.
SELECT User, Host, default_role
FROM mysql.user
WHERE User IN ('m8_default_role_one','m8_default_role_many','m8_combined')
AND default_role <> ''
  ORDER BY User, Host;
User	Host	default_role
m8_combined	%	m8_default_a
m8_default_role_many	%	m8_default_a
m8_default_role_one	%	m8_default_a
