# MDEV-24557 mariadb-dump: translate MySQL 8.x user/grant syntax
#
# test imports a captured mariadb-dump-from-MySQL-8.4.8 output
# (mysql8_users_dump.sql) on MariaDB and checks the MariaDB state
SET NAMES utf8mb4;
CREATE TABLE backup_global_priv   LIKE mysql.global_priv;
CREATE TABLE backup_roles_mapping LIKE mysql.roles_mapping;
CREATE TABLE backup_tables_priv   LIKE mysql.tables_priv;
CREATE TABLE backup_columns_priv  LIKE mysql.columns_priv;
CREATE TABLE backup_procs_priv    LIKE mysql.procs_priv;
CREATE TABLE backup_proxies_priv  LIKE mysql.proxies_priv;
CREATE TABLE backup_db            LIKE mysql.db;
INSERT INTO backup_global_priv   SELECT * FROM mysql.global_priv;
INSERT INTO backup_roles_mapping SELECT * FROM mysql.roles_mapping;
INSERT INTO backup_tables_priv   SELECT * FROM mysql.tables_priv;
INSERT INTO backup_columns_priv  SELECT * FROM mysql.columns_priv;
INSERT INTO backup_procs_priv    SELECT * FROM mysql.procs_priv;
INSERT INTO backup_proxies_priv  SELECT * FROM mysql.proxies_priv;
INSERT INTO backup_db            SELECT * FROM mysql.db;
CREATE DATABASE IF NOT EXISTS m8_db;
CREATE TABLE m8_db.tab (col_a INT, col_underscore_b INT, plain INT);
CREATE TABLE m8_db.tab2 (id INT PRIMARY KEY, payload TEXT);
USE m8_db;
CREATE PROCEDURE proc_one(IN x INT) BEGIN SELECT x; END$$
CREATE FUNCTION  func_one(x INT) RETURNS INT DETERMINISTIC BEGIN RETURN x*2; END$$
USE test;
CREATE DATABASE IF NOT EXISTS `m8_under_score_db`;
CALL mtr.add_suppression('failed to read private_key.pem: 2 "No such file or directory"');
CALL mtr.add_suppression("Plugin 'caching_sha2_password' is of maturity level gamma");
CREATE USER m8_restore IDENTIFIED BY 'r';
GRANT ALL ON *.* TO m8_restore WITH GRANT OPTION;
GRANT PROXY ON ''@'%' TO m8_restore WITH GRANT OPTION;
NOT FOUND /(?:\A|\n)ERROR (?!1396 )\d/ in m8_import.err
DROP USER m8_restore;
# 0a. Captured caching_sha2_password hashes are in the
#     A-format-005 prefix that auth_mysql_sha2 supports. If MySQL
#     bumps the format, the round-trip auth check below silently
#     breaks; this assertion fires loudly instead. If
#     unexpected_count is nonzero, audit auth_mysql_sha2 plugin
#     compatibility against the prefixes shown.
SELECT COUNT(*) AS unexpected_count,
GROUP_CONCAT(DISTINCT
LEFT(JSON_VALUE(Priv, '$.authentication_string'), 6)) AS prefixes
FROM mysql.global_priv
WHERE User LIKE 'm8\\_%'
    AND JSON_VALUE(Priv, '$.plugin') = 'caching_sha2_password'
    AND JSON_VALUE(Priv, '$.authentication_string') NOT LIKE '$A$005$%'
    AND JSON_VALUE(Priv, '$.authentication_string') <> '';
unexpected_count	prefixes
0	NULL
