# === Functional access checks ===
DROP USER ''@'localhost';
# caching_sha2_password preservation (Unix only - gated;
#     'OK' on Windows means skipped, not exercised).
SELECT IF('m8_auth_caching_sha2@%' = 'm8_auth_caching_sha2@%',
'OK',
CONCAT('FAIL: got ', 'm8_auth_caching_sha2@%')) AS caching_sha2_round_trip;
caching_sha2_round_trip
OK
ALTER USER 'm8_simple'@'%'      IDENTIFIED VIA mysql_native_password USING PASSWORD('pw');
ALTER USER 'm8_col_priv'@'%'    IDENTIFIED VIA mysql_native_password USING PASSWORD('pw');
ALTER USER 'm8_role_static'@'%' IDENTIFIED VIA mysql_native_password USING PASSWORD('pw');
ALTER USER 'm8_proc_exec'@'%'   IDENTIFIED VIA mysql_native_password USING PASSWORD('pw');
ALTER USER 'm8_lock'@'%'        IDENTIFIED VIA mysql_native_password USING PASSWORD('pw');
#  m8_simple: schema SELECT works; INSERT denied; role grants overlay.
connect  c_simple, localhost, m8_simple, pw, m8_db;
SELECT COUNT(*) AS rows_visible FROM m8_db.tab;
rows_visible
0
INSERT INTO m8_db.tab VALUES (1,1,1);
ERROR 42000: INSERT command denied to user 'm8_simple'@'localhost' for table `m8_db`.`tab`
SET ROLE m8_role_a;
SELECT COUNT(*) AS rows_via_role FROM m8_db.tab;
rows_via_role
0
disconnect c_simple;
connection default;
# m8_col_priv: SELECT/UPDATE on granted columns; non-granted denied.
connect  c_col, localhost, m8_col_priv, pw, m8_db;
SELECT col_a, col_underscore_b FROM m8_db.tab;
col_a	col_underscore_b
SELECT plain FROM m8_db.tab;
ERROR 42000: SELECT command denied to user 'm8_col_priv'@'localhost' for column 'plain' in table 'tab'
UPDATE m8_db.tab SET col_a = 1 WHERE col_a IS NULL OR col_a IS NOT NULL;
UPDATE m8_db.tab SET plain = 1;
ERROR 42000: UPDATE command denied to user 'm8_col_priv'@'localhost' for column 'plain' in table 'tab'
disconnect c_col;
connection default;
# m8_role_static landed with USAGE only -> CREATE/DROP ROLE denied.
connect  c_rs, localhost, m8_role_static, pw;
CREATE ROLE m8_should_fail_role;
ERROR 42000: Access denied; you need (at least one of) the CREATE USER privilege(s) for this operation
DROP ROLE IF EXISTS m8_role_a;
ERROR 42000: Access denied; you need (at least one of) the CREATE USER privilege(s) for this operation
disconnect c_rs;
connection default;
# m8_admin_chain_root: WITH ADMIN OPTION on m8_role_a is preserved.
SELECT User, Host, Admin_option
FROM mysql.roles_mapping
WHERE User='m8_admin_chain_root' AND Role='m8_role_a';
User	Host	Admin_option
m8_admin_chain_root		Y
# m8_proc_exec: EXECUTE works; DROP PROCEDURE denied.
connect  c_proc, localhost, m8_proc_exec, pw, m8_db;
CALL m8_db.proc_one(42);
x
42
DROP PROCEDURE m8_db.proc_one;
ERROR 42000: alter routine command denied to user 'm8_proc_exec'@'%' for routine 'm8_db.proc_one'
disconnect c_proc;
connection default;
# m8_lock: ACCOUNT LOCK survives import; connect rejected.
connect(localhost,m8_lock,pw,test,MYSQL_PORT,MYSQL_SOCK);
connect  c_lock, localhost, m8_lock, pw;
ERROR HY000: Access denied, this account is locked
SELECT User, Host, JSON_VALUE(Priv, '$.account_locked') AS account_locked
FROM mysql.global_priv WHERE User='m8_lock';
User	Host	account_locked
m8_lock	%	1
#
# Star-slash guard: a role/user/object name containing the star-slash
# sequence must not be emitted inside a /*M!...*/ version comment - it
# would close the comment early and let the trailing bytes run as SQL
# on import.  mariadb-dump refuses such a statement with a # WARNING.
# (The captured MySQL-8 fixture above already carries this for the
# m8_role*/starslash role; here we exercise the emitter directly
# against a MariaDB source.)
#
CREATE ROLE `r_ss*/x`;
CREATE ROLE `r_admin`;
GRANT `r_ss*/x` TO `r_admin` WITH ADMIN OPTION;
# the role name is NOT wrapped in a version comment (expect NOT FOUND):
NOT FOUND //\*M![0-9]* CREATE ROLE 'r_ss/ in m8_starslash_dump.sql
# a # WARNING was emitted in its place (expect FOUND):
FOUND 1 /# WARNING: statement skipped: .* CREATE ROLE 'r_ss/ in m8_starslash_dump.sql
DROP ROLE `r_ss*/x`;
DROP ROLE `r_admin`;
#
# Newline guard: an identifier carrying star-slash AND a newline must
# not let the bytes after the newline escape the '#' WARNING onto a
# line of their own - QUOTE()/backticks do not escape a newline, so a
# '#' comment (which ends at end-of-line) would otherwise run them as
# SQL on import.  The whole diagnostic must stay on one commented line.
#
CREATE ROLE `r_nl*/
INJECTED_NL_MARKER`;
# No '# WARNING' comment line may be immediately followed by a line
# that begins with the marker: that is exactly the injection - the
# newline broke out of the '#' comment so its trailing bytes run as SQL
# on import.  Folded, the marker stays on the same '# WARNING' line, so
# this never matches (expect NOT FOUND).  (The marker does begin lines
# elsewhere, as the wrapped continuation of legitimate backtick-quoted
# GRANT statements, where an in-identifier newline is harmless.)
NOT FOUND /# WARNING[^\n]*\nINJECTED_NL_MARKER/ in m8_newline_dump.sql
DROP ROLE `r_nl*/
INJECTED_NL_MARKER`;
DROP DATABASE IF EXISTS m8_db;
DROP DATABASE IF EXISTS `m8_under_score_db`;
DELETE FROM mysql.global_priv;
DELETE FROM mysql.roles_mapping;
DELETE FROM mysql.tables_priv;
DELETE FROM mysql.columns_priv;
DELETE FROM mysql.procs_priv;
DELETE FROM mysql.proxies_priv;
DELETE FROM mysql.db;
INSERT INTO mysql.global_priv   SELECT * FROM backup_global_priv;
INSERT INTO mysql.roles_mapping SELECT * FROM backup_roles_mapping;
INSERT INTO mysql.tables_priv   SELECT * FROM backup_tables_priv;
INSERT INTO mysql.columns_priv  SELECT * FROM backup_columns_priv;
INSERT INTO mysql.procs_priv    SELECT * FROM backup_procs_priv;
INSERT INTO mysql.proxies_priv  SELECT * FROM backup_proxies_priv;
INSERT INTO mysql.db            SELECT * FROM backup_db;
DROP TABLE backup_global_priv;
DROP TABLE backup_roles_mapping;
DROP TABLE backup_tables_priv;
DROP TABLE backup_columns_priv;
DROP TABLE backup_procs_priv;
DROP TABLE backup_proxies_priv;
DROP TABLE backup_db;
FLUSH PRIVILEGES;
# End of 10.6 tests
