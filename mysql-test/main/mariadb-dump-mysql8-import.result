# 28. COMMENT clause containing '*/' (plain and backslash-escaped).
#     Identifier and clause text aren't wrapped in version comments,
#     so the '*/' is ordinary string content that must round-trip.
SELECT User, Host
FROM mysql.global_priv
WHERE User IN ('m8_starslash_comment','m8_starslash_escaped')
ORDER BY User, Host;
User	Host
m8_starslash_comment	%
m8_starslash_escaped	%
# 29. Partial REVOKE translation. m8_partial_revoke gets a wide
#     GRANT on *.* and a partial REVOKE on m8_db.*. The latter
#     only survives in the dump if partial_revokes was ON during
#     capture (see std_data/mysql8_users_setup.sql Section 18).
SHOW GRANTS FOR 'm8_partial_revoke'@'%';
