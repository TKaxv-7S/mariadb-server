m8_require_ssl	%	1	
m8_require_x509	%	2	
# 23. Combined CREATE USER: many clauses, mix of compat (REQUIRE,
#     WITH MAX_, ACCOUNT LOCK) and dropped (DEFAULT ROLE,
#     PASSWORD HISTORY/REUSE) - the single-pass clause scan.
SELECT User, Host,
JSON_VALUE(Priv, '$.account_locked')        AS account_locked,
JSON_VALUE(Priv, '$.ssl_type')              AS ssl_type,
JSON_VALUE(Priv, '$.max_user_connections')  AS max_user_c
FROM mysql.global_priv
WHERE User='m8_combined' AND Host='%';
User	Host	account_locked	ssl_type	max_user_c
m8_combined	%	1	1	5
SHOW GRANTS FOR 'm8_combined'@'%';
Grants for m8_combined@%
GRANT `m8_default_a` TO `m8_combined`@`%`
GRANT USAGE ON *.* TO `m8_combined`@`%` IDENTIFIED VIA caching_sha2_password USING '$A$005$i1OfA<VRK<Dph&e=F.HDUuym8i5jSx1kneUE0w.TCqkVKJbnQiZdRM6DdHg8' REQUIRE SSL WITH MAX_USER_CONNECTIONS 5
GRANT SELECT ON `m8_db`.* TO `m8_combined`@`%`
SET DEFAULT ROLE `m8_default_a` FOR `m8_combined`@`%`
# 24. Auth plugin coverage: sha256 (dropped+locked), no-pwd, caching_sha2.
#     mysql_native_password is intentionally absent: many MySQL 8.4
#     distros omit the loadable component, so it can't be tested
#     from a fixture script. The unsupported-plugin path (drop the
#     IDENTIFIED clause + warn) is exercised by m8_auth_sha256.
SELECT User, Host,
JSON_VALUE(Priv, '$.plugin')                AS plugin,
LENGTH(JSON_VALUE(Priv, '$.authentication_string')) > 0 AS has_auth_string
FROM mysql.global_priv
WHERE User IN ('m8_auth_sha256','m8_auth_no_pwd','m8_auth_caching_sha2')
ORDER BY User;
User	Host	plugin	has_auth_string
m8_auth_caching_sha2	%	caching_sha2_password	1
m8_auth_no_pwd	%	caching_sha2_password	0
m8_auth_sha256	%	mysql_native_password	0
#     m8_auth_sha256 lost its (unsupported) password, so the
#     translator must have forced ACCOUNT LOCK to keep it unusable.
SELECT JSON_VALUE(Priv, '$.account_locked') AS sha256_locked
FROM mysql.global_priv WHERE User='m8_auth_sha256';
sha256_locked
1
