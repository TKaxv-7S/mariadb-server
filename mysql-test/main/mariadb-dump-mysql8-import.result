# 19. ACCOUNT LOCK / UNLOCK.
SELECT User, Host,
JSON_VALUE(Priv, '$.account_locked') AS account_locked
FROM mysql.global_priv
WHERE User IN ('m8_lock','m8_unlock')
ORDER BY User, Host;
User	Host	account_locked
m8_lock	%	1
m8_unlock	%	0
# 20. PASSWORD EXPIRE variants.
SELECT User, Host,
password_expired,
JSON_VALUE(Priv, '$.password_lifetime') AS password_lifetime
FROM mysql.user
JOIN mysql.global_priv USING (User, Host)
WHERE User IN ('m8_pwd_expire_now','m8_pwd_expire_never',
'm8_pwd_expire_interval','m8_pwd_expire_default')
ORDER BY User;
User	Host	password_expired	password_lifetime
m8_pwd_expire_default	%	N	-1
m8_pwd_expire_interval	%	N	90
m8_pwd_expire_never	%	N	0
m8_pwd_expire_now	%	Y	-1
# 21. Resource limits.
SELECT User, Host,
JSON_VALUE(Priv, '$.max_questions')        AS max_q,
JSON_VALUE(Priv, '$.max_updates')          AS max_u,
JSON_VALUE(Priv, '$.max_connections')      AS max_c,
JSON_VALUE(Priv, '$.max_user_connections') AS max_user_c
FROM mysql.global_priv
WHERE User IN ('m8_max_conn','m8_resource_full')
ORDER BY User;
