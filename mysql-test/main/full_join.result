1	SIMPLE	t3l	ALL	NULL	NULL	NULL	NULL	4	
1	SIMPLE	t3r	ALL	NULL	NULL	NULL	NULL	4	Using where
1	SIMPLE	t3o	ALL	NULL	NULL	NULL	NULL	7	Using where; Using join buffer (flat, BNL join)
select straight_join coalesce(t3l.k, t3r.k) as k, t3o.x
from t3l full join t3r on t3l.k = t3r.k, t3o
where t3o.x between 3 and 4;
