# Nested FULL JOIN on the left of FULL JOIN.
# The inner FULL JOIN's unmatched right-side rows must appear
# in the result even when the outer FULL JOIN condition does
# not reference the inner right-side table.
# Data: t1(1,2) t2(1,3) t3(1,4)
select * from (t1 full join t2 on t1.a=t2.a) full join t3 on t1.a=t3.a;
a	a	a
1	1	1
2	NULL	NULL
NULL	3	NULL
NULL	NULL	4
