select coalesce(t1.a, t2.a) AS a, coalesce(t1.b, t2.b) AS b,
avg(t2.a) AS avg_t2_a from
t1 left join t2 on t2.a = t1.a and t2.b = t1.b where
t1.a is not null group by t1.a;
