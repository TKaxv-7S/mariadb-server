1	NULL	NULL
2	NULL	NULL
NULL	5	50
NULL	6	60
NULL	7	70
select * from t1 left join t2 on t2.pk = 5 and t2.pk = 6
union
select * from t1 right join t2 on t2.pk = 5 and t2.pk = 6;
a	pk	b
1	NULL	NULL
2	NULL	NULL
NULL	5	50
NULL	6	60
NULL	7	70
