Note	1003	select `test`.`t1`.`a` AS `a`,`test`.`t2`.`a` AS `a`,`test`.`t3`.`a` AS `a`,`test`.`t4`.`a` AS `a` from ((`test`.`t1` left join `test`.`t2` on(1)) full join `test`.`t3` on(1)) full join `test`.`t4` on(1) where `test`.`t4`.`a` <= 3000
# IS NOT NULL drives the same rewrite path.
select t1.a, t2.a, t3.a, t4.a
from t1 left join t2 on (true)
full join t3 on (true)
full join t4 on (true)
where t4.a is not null;
