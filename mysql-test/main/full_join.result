coalesce(t3l.k, t3r.k) as klr, t3o.x,
coalesce(t3m.k, t3n.k) as kmn
from (t3l full join t3r on t3l.k = t3r.k),
t3o,
(t3m full join t3n on t3m.k = t3n.k)
where t3o.x between 3 and 4;
