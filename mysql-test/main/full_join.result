create table t1 (pk int);
create table t2 (pk int);
create table t3 (pk int);
create table t4 (pk int);
insert into t1 values (1), (2);
select t1.pk from t1
full join t2
full outer join t3 on (true)
full join t4 on (true)
on t1.pk = t4.pk;
