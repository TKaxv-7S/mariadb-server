1	5	50
2	5	50
NULL	6	60
NULL	7	70
select * from t1 left join t2 on t2.b = 50
union
select * from t1 right join t2 on t2.b = 50;
a	pk	b
1	5	50
2	5	50
NULL	6	60
NULL	7	70
