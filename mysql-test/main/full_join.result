# UNION equivalent of the aggregate above.
select dt.a, dt.b, avg(dt.t2a) as `avg(t2.a)` from (
select t1.a as a, t1.b as b, t2.a as t2a from t1 natural left join t2
union
select t1.a, t1.b, t2.a from t1 natural right join t2) dt
where dt.a is not null group by dt.a;
