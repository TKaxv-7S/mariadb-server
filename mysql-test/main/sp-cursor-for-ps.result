CREATE PROCEDURE p1 AS
c0 SYS_REFCURSOR;
v0 TEXT;
ps_name VARCHAR(30) := 'àçé';
BEGIN
PREPARE àçé FROM 'SELECT 10';
OPEN c0 FOR LOCAL ps_name;
FETCH c0 INTO v0;
CLOSE c0;
