#
# MDEV-39518 Allow prepared statements in stored functions in assignment right hand
#
# Testing various stack combinations
# p1, f2, p3_direct_immediate
CREATE TABLE t1 (a INT);
CREATE PROCEDURE p3_direct_immediate()
BEGIN
EXECUTE IMMEDIATE 'INSERT INTO t1 VALUES (9)';
INSERT INTO t1 VALUES (10);
END;
$$
CREATE FUNCTION f2() RETURNS INT
BEGIN
CALL p3_direct_immediate();
RETURN 0;
END;
$$
CREATE PROCEDURE p1_set()
BEGIN
DECLARE nrows INT;
SET nrows= f2();
END;
$$
CREATE PROCEDURE p1_select()
BEGIN
SELECT f2();
END;
$$
CREATE PROCEDURE p1_default()
BEGIN
DECLARE nrows INT DEFAULT f2();
END;
$$
CALL p1_select();
ERROR 0A000: Dynamic SQL is not allowed in stored function or trigger
CALL p1_select();
ERROR 0A000: Dynamic SQL is not allowed in stored function or trigger
SELECT * FROM t1;
a
TRUNCATE TABLE t1;
CALL p1_set;
SELECT * FROM t1;
a
9
10
CALL p1_set;
SELECT * FROM t1;
a
9
10
9
10
TRUNCATE TABLE t1;
CALL p1_default;
SELECT * FROM t1;
a
9
10
CALL p1_default;
SELECT * FROM t1;
a
9
10
9
10
DROP PROCEDURE p1_default;
DROP PROCEDURE p1_set;
DROP PROCEDURE p1_select;
DROP FUNCTION f2;
DROP PROCEDURE p3_direct_immediate;
DROP TABLE t1;
# p1, f2, p3_immediate_direct
