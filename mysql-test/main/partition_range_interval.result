# DATETIME column with some decimal points in partition range value
create table t1 (c datetime) engine=innodb
PARTITION BY RANGE COLUMNS (c)
INTERVAL 1 hour
(
PARTITION p0 VALUES LESS THAN ('2026-05-05 01:23:45.6789')
);
