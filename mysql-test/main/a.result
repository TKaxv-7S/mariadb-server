  `a` text DEFAULT NULL,
  FULLTEXT KEY `a` (`a`) USING TABLE
) ENGINE=MyISAM DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_uca1400_ai_ci
drop table t1;
set old_mode='';
create table t1 (a text not null, b vector(10) not null, fulltext (a), vector(b));
