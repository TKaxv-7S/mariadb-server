create table t1 (a text not null, b varchar(10) not null, fulltext(b), fulltext (a));
ERROR 42000: This version of MariaDB doesn't yet support 'multiple VECTOR/FULLTEXT indexes'
create table t1 (a text not null, fulltext (a));
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `a` text NOT NULL,
  FULLTEXT KEY `a` (`a`)
) ENGINE=MyISAM DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_uca1400_ai_ci
drop table t1;
CREATE TABLE t1 (a VARCHAR(200), b TEXT, FULLTEXT (a,b));
