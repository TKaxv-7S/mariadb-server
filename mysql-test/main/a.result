create table t1 (a text, fulltext (a) using engine);
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `a` text DEFAULT NULL,
  FULLTEXT KEY `a` (`a`) USING ENGINE
) ENGINE=MyISAM DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_uca1400_ai_ci
drop table t1;
