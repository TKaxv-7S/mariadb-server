#
# MDEV-39492 Parallel Query: worker-side execution.
#
# Each parallel worker runs the whole select-project query over its disjoint
# chunk of the source table -- WHERE filtering and select-list projection --
# and ships the final result rows to the manager, which only concatenates and
# sends them. This test checks that the result is identical to serial
# execution (the workers' chunks are disjoint and exhaustive, so concatenation
# is the correct full result), and that the worker-side path is actually taken.
#
--source include/have_innodb.inc
--source include/have_sequence.inc
--source include/not_embedded.inc

CREATE TABLE t1 (a INT, b INT, c VARCHAR(20)) ENGINE=InnoDB;
INSERT INTO t1
  SELECT seq, seq * 10, CONCAT('row-', seq) FROM seq_1_to_5000;

SET @save= @@session.parallel_worker_threads;

# --- correctness: worker-side result set == serial result set ----------------
# Build the same query's output once serially and once with 4 workers; the two
# result sets must be identical (same rows, same multiplicity).

SET SESSION parallel_worker_threads= 0;
CREATE TEMPORARY TABLE t_serial ENGINE=InnoDB AS
  SELECT a, b, c FROM t1 WHERE a % 7 = 0 AND b > 100;

SET SESSION parallel_worker_threads= 4;
CREATE TEMPORARY TABLE t_par ENGINE=InnoDB AS
  SELECT a, b, c FROM t1 WHERE a % 7 = 0 AND b > 100;

--echo # same number of rows serially and in parallel (expect equal, non-zero)
SELECT (SELECT COUNT(*) FROM t_serial) AS serial_rows,
       (SELECT COUNT(*) FROM t_par)    AS par_rows;

--echo # symmetric difference of the two result sets is empty (expect 0 and 0)
SELECT COUNT(*) AS only_in_serial
  FROM (SELECT a,b,c FROM t_serial EXCEPT SELECT a,b,c FROM t_par) x;
SELECT COUNT(*) AS only_in_parallel
  FROM (SELECT a,b,c FROM t_par EXCEPT SELECT a,b,c FROM t_serial) y;

DROP TEMPORARY TABLE t_serial, t_par;

# --- projection of expressions, and a no-WHERE scan --------------------------
--echo # projected expressions, sorted for a stable comparison
--sorted_result
SELECT a, a + b AS sum_ab, UPPER(c) AS uc FROM t1 WHERE a BETWEEN 4990 AND 5000;

--echo # whole-table scan (no WHERE), counted
SELECT COUNT(*) AS n FROM (SELECT a, b, c FROM t1) d;

# --- queries that do NOT qualify must fall back to serial, still correct -----
# (run with workers enabled; the gate declines, the query runs serially)
CREATE TABLE t2 (id INT PRIMARY KEY, label VARCHAR(20)) ENGINE=InnoDB;
INSERT INTO t2 SELECT seq, CONCAT('L', seq) FROM seq_1_to_50;

--echo # multi-table join (more than one non-const table): correct join result
--sorted_result
SELECT t1.a, t2.label FROM t1 JOIN t2 ON t2.id = t1.a WHERE t1.a IN (3,17,42);

--echo # aggregation / GROUP BY: correct grouped result
SELECT a % 3 AS g, COUNT(*) AS n, SUM(b) AS s FROM t1 GROUP BY a % 3 ORDER BY g;

--echo # ORDER BY with LIMIT: correct top-N
SELECT a, b FROM t1 WHERE a > 100 ORDER BY a LIMIT 5;

DROP TABLE t2;

# --- confirm the worker-side path is actually chosen -------------------------
SET @save_ot= @@optimizer_trace;
SET optimizer_trace='enabled=on';
--disable_result_log
SELECT a, b FROM t1 WHERE a > 0;
--enable_result_log
--echo # worker-side parallel query was chosen for the scan (expect 1)
SELECT JSON_EXTRACT(trace, '$**.chosen_for_parallel_scan') IS NOT NULL
       AS chosen
  FROM information_schema.optimizer_trace;

--echo # a query that does NOT qualify (ORDER BY needs a global sort): not chosen
--disable_result_log
SELECT a FROM t1 WHERE a > 0 ORDER BY a;
--enable_result_log
--echo # expect 0
SELECT JSON_EXTRACT(trace, '$**.chosen_for_parallel_scan') IS NOT NULL
       AS chosen
  FROM information_schema.optimizer_trace;
SET optimizer_trace= @save_ot;

SET SESSION parallel_worker_threads= @save;
DROP TABLE t1;
