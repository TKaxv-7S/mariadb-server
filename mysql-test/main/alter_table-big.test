#
# Tests for various concurrency-related aspects of ALTER TABLE implemetation
#
# This test takes rather long time so let us run it only in --big-test mode
--source include/big_test.inc
# We are using some debug-only features in this test
--source include/have_debug.inc
--source include/have_debug_sync.inc
# Also we are using SBR to check that statements are executed
# in proper order.
--source include/have_binlog_format_mixed_or_statement.inc

#
# Test for Bug#25044 ALTER TABLE ... ENABLE KEYS acquires global
#                    'opening tables' lock
#
# ALTER TABLE ... ENABLE KEYS should not acquire LOCK_open mutex for
# the whole its duration as it prevents other queries from execution.
--disable_warnings
drop table if exists t1, t2;
--enable_warnings
set debug_sync='RESET';

connect (addconroot, localhost, root,,);
connect (addconroot2, localhost, root,,);
connection default;
create table t1 (n1 int, n2 int, n3 int,
                key (n1, n2, n3),
                key (n2, n3, n1),
                key (n3, n1, n2));
create table t2 (i int);

alter table t1 disable keys;
insert into t1 values (1, 2, 3);

# Later we use binlog to check the order in which statements are
# executed so let us reset it first.
reset master;
set debug_sync='alter_table_enable_indexes SIGNAL parked WAIT_FOR go';
--send alter table t1 enable keys;
connection addconroot;
# Wait until ALTER TABLE acquires metadata lock.
set debug_sync='now WAIT_FOR parked';
# This statement should not be blocked by in-flight ALTER and therefore
# should be executed and written to binlog before ALTER TABLE ... ENABLE KEYS
# finishes.
insert into t2 values (1);
# And this should wait until the end of ALTER TABLE ... ENABLE KEYS.
--send insert into t1 values (1, 1, 1);
connection addconroot2;
# Wait until the above INSERT INTO t1 is blocked due to ALTER
let $wait_condition=
    select count(*) = 1 from information_schema.processlist
    where state = "Waiting for table metadata lock" and
          info = "insert into t1 values (1, 1, 1)";
--source include/wait_condition.inc
# Resume ALTER execution.
set debug_sync='now SIGNAL go';
connection default;
--reap
connection addconroot;
--reap
connection default;
# Check that statements were executed/binlogged in correct order.
source include/show_binlog_events.inc;

# Clean up
drop tables t1, t2;
disconnect addconroot;
disconnect addconroot2;
set debug_sync='RESET';

--echo End of 5.0 tests

#
# Additional coverage for the main ALTER TABLE case
#
# We should be sure that table being altered is properly
# locked during statement execution and in particular that
# no DDL or DML statement can sneak in and get access to
# the table when real operation has already taken place
# but this fact has not been noted in binary log yet.
--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings
connect (addconroot, localhost, root,,);
connect (addconroot2, localhost, root,,);
connection default;
create table t1 (i int);
# We are going to check that statements are logged in correct order
reset master;
set debug_sync='alter_table_before_main_binlog SIGNAL parked WAIT_FOR go';
--send alter table t1 change i c char(10) default 'Test1';
connection addconroot;
# Wait until ALTER TABLE acquires metadata lock.
set debug_sync='now WAIT_FOR parked'; 
--send insert into t1 values ();
connection addconroot2;
# Wait until the above INSERT INTO t1 is blocked due to ALTER
let $wait_condition=
    select count(*) = 1 from information_schema.processlist
    where state = "Waiting for table metadata lock" and
          info = "insert into t1 values ()";
--source include/wait_condition.inc
# Resume ALTER execution.
set debug_sync='now SIGNAL go';
connection default;
--reap
connection addconroot;
--reap
connection default;
select * from t1;
set debug_sync='alter_table_before_main_binlog SIGNAL parked WAIT_FOR go';
--send alter table t1 change c vc varchar(100) default 'Test2';
connection addconroot;
# Wait until ALTER TABLE acquires metadata lock.
set debug_sync='now WAIT_FOR parked';
--send rename table t1 to t2;
connection addconroot2;
# Wait until the above RENAME TABLE is blocked due to ALTER
let $wait_condition=
    select count(*) = 1 from information_schema.processlist
    where state = "Waiting for table metadata lock" and
          info = "rename table t1 to t2";
--source include/wait_condition.inc
# Resume ALTER execution.
set debug_sync='now SIGNAL go';
connection default;
--reap
connection addconroot;
--reap
connection default;
drop table t2;
# And now tests for ALTER TABLE with RENAME clause. In this
# case target table name should be properly locked as well.
create table t1 (i int);
set debug_sync='alter_table_before_main_binlog SIGNAL parked WAIT_FOR go';
--send alter table t1 change i c char(10) default 'Test3', rename to t2;
connection addconroot;
# Wait until ALTER TABLE acquires metadata lock.
set debug_sync='now WAIT_FOR parked';
--send insert into t2 values();
connection addconroot2;
# Wait until the above INSERT INTO t2 is blocked due to ALTER
let $wait_condition=
    select count(*) = 1 from information_schema.processlist
    where state = "Waiting for table metadata lock" and
           info = "insert into t2 values()";
--source include/wait_condition.inc
# Resume ALTER execution.
set debug_sync='now SIGNAL go';
connection default;
--reap
connection addconroot;
--reap
connection default;
select * from t2;
--send alter table t2 change c vc varchar(100) default 'Test2', rename to t1;
connection addconroot;
connection default;
--reap
rename table t1 to t3;

disconnect addconroot;
disconnect addconroot2;
drop table t3;
set debug_sync='alter_table_before_main_binlog SIGNAL parked WAIT_FOR go';
set debug_sync='RESET';

# Check that all statements were logged in correct order
source include/show_binlog_events.inc;


--echo End of 5.1 tests

--echo #
--echo # MDEV-39184: Assertion failure in TDC_element::flush()
--echo # when LOCK TABLE WRITE + ALTER TABLE DISCARD/IMPORT TABLESPACE
--echo #

--source include/have_innodb.inc

# Get datadir for file operations
let $MYSQLD_DATADIR = `SELECT @@datadir`;

# Suppress expected warnings
call mtr.add_suppression("InnoDB: Tablespace for table test/t");
call mtr.add_suppression("InnoDB: Cannot open datafile for read-write");

--echo #
--echo # ============================================================
--echo # SECTION 1: DISCARD TABLESPACE UNDER LOCK TABLE
--echo # ============================================================
--echo #

CREATE TABLE t (s INT) ENGINE=InnoDB;
INSERT INTO t VALUES (1),(2),(3);
SELECT * FROM t ORDER BY s;

--echo #
--echo # Scenario 1.1: Original bug
--echo # LOCK TABLE WRITE + DISCARD TABLESPACE
--echo # Previously crashed server with assertion failure in
--echo # TDC_element::flush() — MDL_EXCLUSIVE was not held
--echo #
LOCK TABLE t WRITE;
ALTER TABLE t DISCARD TABLESPACE;
UNLOCK TABLES;
DROP TABLE IF EXISTS t;

--echo #
--echo # Scenario 1.2: DISCARD without LOCK TABLE
--echo # Normal flow — regression check
--echo #
CREATE TABLE t (s INT) ENGINE=InnoDB;
INSERT INTO t VALUES (1),(2),(3);
ALTER TABLE t DISCARD TABLESPACE;
DROP TABLE IF EXISTS t;

--echo #
--echo # Scenario 1.3: LOCK TABLE READ + DISCARD
--echo # Should give lock error not crash
--echo #
CREATE TABLE t (s INT) ENGINE=InnoDB;
LOCK TABLE t READ;
--error ER_TABLE_NOT_LOCKED_FOR_WRITE
ALTER TABLE t DISCARD TABLESPACE;
UNLOCK TABLES;
DROP TABLE IF EXISTS t;


--echo #
--echo # Scenario 1.4: Session still usable after DISCARD under LOCK TABLE
--echo # Lock state and other tables must be preserved
--echo #
CREATE TABLE t  (s INT) ENGINE=InnoDB;
CREATE TABLE t2 (s INT) ENGINE=InnoDB;
INSERT INTO t2 VALUES (1),(2),(3);

LOCK TABLE t WRITE, t2 WRITE;
ALTER TABLE t DISCARD TABLESPACE;
--echo # t2 should still be accessible — session not broken
SELECT * FROM t2 ORDER BY s;
UNLOCK TABLES;

DROP TABLE IF EXISTS t;
DROP TABLE IF EXISTS t2;

--echo #
--echo # Scenario 1.5: Multiple tables DISCARD in same locked session
--echo #
CREATE TABLE t  (s INT) ENGINE=InnoDB;
CREATE TABLE t2 (s INT) ENGINE=InnoDB;

LOCK TABLE t WRITE, t2 WRITE;
ALTER TABLE t  DISCARD TABLESPACE;
ALTER TABLE t2 DISCARD TABLESPACE;
UNLOCK TABLES;

DROP TABLE IF EXISTS t;
DROP TABLE IF EXISTS t2;


--echo #
--echo # ============================================================
--echo # SECTION 2: IMPORT TABLESPACE UNDER LOCK TABLE
--echo # Uses real .ibd file copy like reference test
--echo # ============================================================
--echo #

--echo #
--echo # Scenario 2.1: Full DISCARD + IMPORT cycle under LOCK TABLE
--echo # Create valid .ibd via FLUSH TABLE FOR EXPORT
--echo # then DISCARD and IMPORT under LOCK TABLE
--echo #

# Step 1: create table and get a valid .ibd backup
CREATE TABLE t (s INT) ENGINE=InnoDB;
INSERT INTO t VALUES (10),(20),(30);
SELECT * FROM t ORDER BY s;

# Export to get consistent .ibd + .cfg
FLUSH TABLE t FOR EXPORT;
--copy_file $MYSQLD_DATADIR/test/t.cfg $MYSQLD_DATADIR/t_backup.cfg
--copy_file $MYSQLD_DATADIR/test/t.ibd $MYSQLD_DATADIR/t_backup.ibd
UNLOCK TABLES;

# Step 2: DISCARD under LOCK TABLE — main fix being tested
LOCK TABLE t WRITE;
ALTER TABLE t DISCARD TABLESPACE;
UNLOCK TABLES;

# Step 3: restore the backed up .ibd and .cfg
--move_file $MYSQLD_DATADIR/t_backup.cfg $MYSQLD_DATADIR/test/t.cfg
--move_file $MYSQLD_DATADIR/t_backup.ibd $MYSQLD_DATADIR/test/t.ibd

# Step 4: IMPORT under LOCK TABLE
LOCK TABLE t WRITE;
ALTER TABLE t IMPORT TABLESPACE;
UNLOCK TABLES;

# Step 5: verify data is restored
SELECT * FROM t ORDER BY s;

DROP TABLE IF EXISTS t;

--echo #
--echo # Scenario 2.2: DISCARD then IMPORT in same locked session
--echo # Both operations under same LOCK TABLE
--echo #
CREATE TABLE t (s INT) ENGINE=InnoDB;
INSERT INTO t VALUES (1),(2),(3);

FLUSH TABLE t FOR EXPORT;
--copy_file $MYSQLD_DATADIR/test/t.cfg $MYSQLD_DATADIR/t_backup.cfg
--copy_file $MYSQLD_DATADIR/test/t.ibd $MYSQLD_DATADIR/t_backup.ibd
UNLOCK TABLES;

# Both DISCARD and IMPORT in same locked session
LOCK TABLE t WRITE;
ALTER TABLE t DISCARD TABLESPACE;

--move_file $MYSQLD_DATADIR/t_backup.cfg $MYSQLD_DATADIR/test/t.cfg
--move_file $MYSQLD_DATADIR/t_backup.ibd $MYSQLD_DATADIR/test/t.ibd

ALTER TABLE t IMPORT TABLESPACE;
UNLOCK TABLES;

SELECT * FROM t ORDER BY s;
DROP TABLE IF EXISTS t;

--echo #
--echo # Scenario 2.3: IMPORT without LOCK TABLE
--echo # Normal path — regression check
--echo #
CREATE TABLE t (s INT) ENGINE=InnoDB;
INSERT INTO t VALUES (1),(2),(3);

FLUSH TABLE t FOR EXPORT;
--copy_file $MYSQLD_DATADIR/test/t.cfg $MYSQLD_DATADIR/t_backup.cfg
--copy_file $MYSQLD_DATADIR/test/t.ibd $MYSQLD_DATADIR/t_backup.ibd
UNLOCK TABLES;

ALTER TABLE t DISCARD TABLESPACE;

--move_file $MYSQLD_DATADIR/t_backup.cfg $MYSQLD_DATADIR/test/t.cfg
--move_file $MYSQLD_DATADIR/t_backup.ibd $MYSQLD_DATADIR/test/t.ibd

ALTER TABLE t IMPORT TABLESPACE;
SELECT * FROM t ORDER BY s;
DROP TABLE IF EXISTS t;

--echo #
--echo # Scenario 2.4: Session intact after IMPORT under LOCK TABLE
--echo #
CREATE TABLE t  (s INT) ENGINE=InnoDB;
CREATE TABLE t2 (s INT) ENGINE=InnoDB;
INSERT INTO t2 VALUES (1),(2),(3);

FLUSH TABLE t FOR EXPORT;
--copy_file $MYSQLD_DATADIR/test/t.cfg $MYSQLD_DATADIR/t_backup.cfg
--copy_file $MYSQLD_DATADIR/test/t.ibd $MYSQLD_DATADIR/t_backup.ibd
UNLOCK TABLES;

LOCK TABLE t WRITE, t2 WRITE;
ALTER TABLE t DISCARD TABLESPACE;

--move_file $MYSQLD_DATADIR/t_backup.cfg $MYSQLD_DATADIR/test/t.cfg
--move_file $MYSQLD_DATADIR/t_backup.ibd $MYSQLD_DATADIR/test/t.ibd

ALTER TABLE t IMPORT TABLESPACE;

--echo # t2 still accessible after IMPORT — session not broken
SELECT * FROM t2 ORDER BY s;
UNLOCK TABLES;

DROP TABLE IF EXISTS t;
DROP TABLE IF EXISTS t2;


--echo #
--echo # ============================================================
--echo # SECTION 3: TEMPORARY TABLE HANDLING
--echo # ============================================================
--echo #

--echo #
--echo # Scenario 3.1: DISCARD on temporary table without LOCK TABLE
--echo # InnoDB does not support DISCARD on temp tables
--echo #
CREATE TEMPORARY TABLE tmp (s INT) ENGINE=InnoDB;
--error ER_CANNOT_DISCARD_TEMPORARY_TABLE
ALTER TABLE tmp DISCARD TABLESPACE;
DROP TEMPORARY TABLE tmp;

--echo #
--echo # Scenario 3.2: DISCARD on temporary table under LOCK TABLE
--echo # Must not crash — wait_while_table_is_used() has internal
--echo # DBUG_ASSERT(!tmp_table) which crashes without the guard
--echo # added in the fix (tmp_table == NO_TMP_TABLE check)
--echo #
CREATE TEMPORARY TABLE tmp (s INT) ENGINE=InnoDB;
LOCK TABLE tmp WRITE;
--error ER_CANNOT_DISCARD_TEMPORARY_TABLE
ALTER TABLE tmp DISCARD TABLESPACE;
UNLOCK TABLES;
DROP TEMPORARY TABLE tmp;

--echo #
--echo # Scenario 3.3: IMPORT on temporary table under LOCK TABLE
--echo # Same guard must protect IMPORT path too
--echo #
CREATE TEMPORARY TABLE tmp (s INT) ENGINE=InnoDB;
LOCK TABLE tmp WRITE;
--error ER_CANNOT_DISCARD_TEMPORARY_TABLE
ALTER TABLE tmp IMPORT TABLESPACE;
UNLOCK TABLES;
DROP TEMPORARY TABLE tmp;
