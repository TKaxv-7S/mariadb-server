--echo
--echo <group>
--echo

set @schema= ' <?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">

  <!-- 1. DEFINE THE REUSABLE GROUP -->
  <xs:group name="ContactAndShippingGroup">
    <xs:sequence>
      <xs:element name="CustomerName" type="xs:string"/>
      <xs:element name="Email" type="xs:string"/>
      <xs:element name="ShippingAddress" type="xs:string"/>
    </xs:sequence>
  </xs:group>

  <!-- 2. USE THE GROUP IN A COMPLEX TYPE (Regular Order) -->
  <xs:complexType name="RegularOrderType">
    <xs:sequence>
      <!-- Insert the group here -->
      <xs:group ref="ContactAndShippingGroup"/>
      <xs:element name="OrderDate" type="xs:date"/>
    </xs:sequence>
  </xs:complexType>

  <!-- 3. USE THE GROUP IN ANOTHER COMPLEX TYPE (Express Order) -->
  <xs:complexType name="ExpressOrderType">
    <xs:sequence>
      <!-- Insert the exact same group here -->
      <xs:group ref="ContactAndShippingGroup"/>
      <xs:element name="CourierName" type="xs:string"/>
      <xs:element name="ExpectedDelivery" type="xs:dateTime"/>
    </xs:sequence>
  </xs:complexType>

  <!-- Define the root elements to make the schema valid -->
  <xs:element name="RegularOrder" type="RegularOrderType"/>
  <xs:element name="ExpressOrder" type="ExpressOrderType"/>

</xs:schema> ';

set @xml= '
<RegularOrder>
  <!-- Group Elements Start -->
  <CustomerName>Alex Mercer</CustomerName>
  <Email>alex.m@example.com</Email>
  <ShippingAddress>
    <Street>Lont st. 123</Street>
    <zip>0123456</zip>
  </ShippingAddress>
  <!-- Group Elements End -->
  <OrderDate>2026-06-01</OrderDate>
</RegularOrder>';

select XMLISVALID(@xml, @schema);

