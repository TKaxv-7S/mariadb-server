set @schema= '<?xml version="1.0"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">

<!-- Main Element -->
  <xs:element name="payment">
    <!-- Defines the element as having child items -->
    <xs:complexType>
      <!-- Dictates that only ONE of the following elements can be used -->
      <xs:choice>
        <xs:element name="creditcard" type="xs:string" />
        <xs:element name="paypal" type="xs:string" />
      </xs:choice>
    </xs:complexType>
  </xs:element>

</xs:schema>';

set @xml= '
<payment>
  <creditcard>1234-5678-9012-3456</creditcard>
</payment>';

select XMLISVALID(@xml, @schema);

