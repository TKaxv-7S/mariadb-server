replace_result InnoDB MyISAM;

set @xml= '<a> If <b> 123 </b> </a>';

select XMLISVALID(@xml, NULL);

CREATE TABLE t1(v varchar(100));
INSERT INTO t1 VALUES ("one"), ("two");

--error ER_UNKNOWN_ERROR
SELECT XMLISVALID(@xml, v) FROM t1;
DROP TABLE t1;

set @schema= '<?xml version="1.0"?>
<xs:something xmlns:xs="http://www.w3.org/2001/XMLSchema">
  <xs:element name="note" type="xs:string"/>
</xs:something>';

set @xml= '<a> If <b> 123 </b> </a>';

--error ER_UNKNOWN_ERROR
select XMLISVALID(@xml, @schema);

set @schema= '<?xml version="1.0"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">

<xs:element name="note">
  <xs:complexType>
    <xs:sequence>
      <xs:element name="to" type="xs:string"/>
      <xs:element name="from" type="xs:string"/>
      <xs:element name="heading" type="xs:string"/>
      <xs:element name="body" type="xs:string"/>
    </xs:sequence>
  </xs:complexType>
</xs:element>

</xs:schema>';


set @xml= '<a> If <b> 123 </b> </a>';

select XMLISVALID(@xml, @schema);

set @xml= '<?xml version="1.0"?>
<note>
  <to>JOHN</to>
  <from>MARY</from>
  <heading>Reminder</heading>
  <body>Take care!</body>
</note>';

select XMLISVALID(@xml, @schema);

--echo
--echo trigger with XMLISVALID.
--echo

CREATE TABLE t1 (a XMLType);

--delimiter $$

CREATE TRIGGER trg BEFORE INSERT ON t1 FOR EACH ROW
BEGIN
  if XMLISVALID(NEW.a, '<xs:schema> <xs:element name="person" type="xs:string" /> </xs:schema>') = 0 then
      SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'XML Schema validation failed';
   end if;
END
$$

--delimiter ;

--error ER_SIGNAL_EXCEPTION
INSERT INTO t1 VALUES ('<a> If <b> 123 </b> </a>');
INSERT INTO t1 VALUES ('<person> John Doe </person>');
SELECT * FROM t1;
DROP TABLE t1;

create table t1 (a xmltype
   check (XMLISVALID(a, '<xs:schema> <xs:element name="person" type="xs:string" /> </xs:schema>')));

--error ER_CONSTRAINT_FAILED
INSERT INTO t1 VALUES ('<a> If <b> 123 </b> </a>');
INSERT INTO t1 VALUES ('<person> John Doe </person>');
SELECT * FROM t1;
DROP TABLE t1;

