set @schema= ' <?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">

 <!-- Define the union type using built-in types -->
   <xs:simpleType name="ShirtSizeType">
      <xs:union memberTypes="xs:integer xs:string"/>
   </xs:simpleType>

 <!-- Apply it to an element -->
   <xs:element name="size" type="ShirtSizeType"/>

</xs:schema> ';

set @xml= '<size>95</size>';
select XMLISVALID(@xml, @schema);

set @xml= '<size>absent</size>';

select XMLISVALID(@xml, @schema);

set @schema= ' <?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">

<xs:simpleType name="ExamScoreType">
  <xs:union>
    
    <!-- Member Type 1: Numeric restriction -->
    <xs:simpleType>
      <xs:restriction base="xs:integer">
        <xs:minInclusive value="0"/>
        <xs:maxInclusive value="100"/>
      </xs:restriction>
    </xs:simpleType>
    
    <!-- Member Type 2: Text string restriction -->
    <xs:simpleType>
      <xs:restriction base="xs:string">
        <xs:enumeration value="absent"/>
      </xs:restriction>
    </xs:simpleType>
    
  </xs:union>
</xs:simpleType>

   <xs:element name="score" type="ExamScoreType"/>

</xs:schema> ';

set @xml= '<score>95</score>';
select XMLISVALID(@xml, @schema);

set @xml= '<score>absent</score>';

select XMLISVALID(@xml, @schema);

