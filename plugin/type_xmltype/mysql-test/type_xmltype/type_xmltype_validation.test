set @schema= '<?xml version="1.0"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">
   <xs:annotation>
      <!-- For humans: documentation tools and developers -->
      <xs:documentation xml:lang="en">
        This element represents a retail product item in the inventory system.
      </xs:documentation>
        
      <!-- For machines: code generators, validators, or internal apps -->
      <xs:appinfo>
        <xs:database-table>inventory_products</xs:database-table>
      </xs:appinfo>
    </xs:annotation>

  <!-- Main Element -->
  <xs:element name="person">
    <!-- Defines the element as having child items -->
    <xs:complexType>
       <xs:annotation>
          <!-- For humans: documentation tools and developers -->
          <xs:documentation xml:lang="en">
            This element represents a retail product item in the inventory system.
          </xs:documentation>
        
          <!-- For machines: code generators, validators, or internal apps -->
          <xs:appinfo>
            <xs:database-table>inventory_products</xs:database-table>
          </xs:appinfo>
        </xs:annotation>

      <!-- Dictates children can appear in any sequence -->
      <xs:all>
        <xs:element name="firstname" type="xs:string" />
        <xs:element name="lastname" type="xs:string" />
        <xs:element name="age" type="xs:int" />
      </xs:all>
    </xs:complexType>
  </xs:element>

</xs:schema>';

