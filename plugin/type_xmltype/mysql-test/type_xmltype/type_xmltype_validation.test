set @schema= ' <?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">

  <xs:element name="person">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="firstName" type="xs:string"/>
        <xs:element name="lastName" type="xs:string"/>
        <!-- Extensibility point: allows any elements after the last name -->
        <xs:any namespace="##any" processContents="lax" minOccurs="0" maxOccurs="unbounded"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>

</xs:schema> ';

set @xml= '
<person>
  <firstName>John</firstName>
  <lastName>Doe</lastName>
  <!-- The following elements are allowed by <xs:any> -->
  <age>30</age>
  <city>New York</city>
</person> ';

select XMLISVALID(@xml, @schema);


--echo
--echo <attributeGroup>
--echo

set @schema= ' <?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">

<!-- 1. Define the attribute group -->
  <xs:attributeGroup name="personIdentDetails">
    <xs:attribute name="id" type="xs:string" use="required"/>
    <xs:attribute name="status" type="xs:string" use="optional"/>
  </xs:attributeGroup>

  <!-- 2. Reuse the group in elements -->
  <xs:element name="employee">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="name" type="xs:string"/>
      </xs:sequence>
      <!-- Reference the group here -->
      <xs:attributeGroup ref="personIdentDetails"/>
    </xs:complexType>
  </xs:element>

  <xs:element name="visitor">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="company" type="xs:string"/>
      </xs:sequence>
      <!-- Reference the same group here -->
      <xs:attributeGroup ref="personIdentDetails"/>
    </xs:complexType>
  </xs:element>
</xs:schema> ';

set @xml= '
<employee id="EMP1024" status="active">
    <name>Jane Doe</name>
</employee>';

select XMLISVALID(@xml, @schema);

set @xml= '
<visitor id="VIS-9951" status="active">
    <company>Acme Corporation</company>
</visitor>';

select XMLISVALID(@xml, @schema);

