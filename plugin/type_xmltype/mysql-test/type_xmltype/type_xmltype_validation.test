      <xs:element name="t3" type="xs:short"/>
      <xs:element name="t4" type="xs:byte"/>
      <xs:element name="t5" type="xs:nonNegativeInteger"/>
      <xs:element name="t6" type="xs:positiveInteger"/>
      <xs:element name="t7" type="xs:unsignedLong"/>
      <xs:element name="t8" type="xs:double"/>
      <xs:element name="t9" type="xs:float"/>
      <xs:element name="t10" type="xs:anySimpleType"/>
    </xs:sequence>
  </xs:complexType>
</xs:element>

</xs:schema>';

